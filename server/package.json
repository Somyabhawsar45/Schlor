{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node ./node_modules/nodemon/bin/nodemon.js index.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "jest": {
  "watchman": false,
  "testEnvironment": "node",
  "testTimeout": 30000,
  "setupFilesAfterEnv": [
    "./tests/setup.js"
  ],
  "transformIgnorePatterns": [
    "node_modules/(?!(uuid)/)"
  ],
  "testMatch": [
    "<rootDir>/tests/*.test.js"
  ]
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "nodemailer": "^9.0.0",
    "nodemon": "^3.1.14",
    "otp-generator": "^4.0.1",
    "puppeteer-core": "^23.0.0",
"@sparticuz/chromium": "^123.0.0",
    "razorpay": "^2.9.6",
    "resend": "^6.14.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
